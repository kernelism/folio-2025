---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  date?: string;
  description?: string;
}

const { title, date, description } = Astro.props;
---

<BaseLayout title={`${title} — Arjhun Sreedar`} description={description}>
  <nav class="blog-nav">
    <a href="/" class="link-hover">← home</a>
    <a href="/blog" class="link-hover">blog</a>
  </nav>

  <article class="blog-article">
    <header class="blog-header">
      <h1 class="blog-title">{title}</h1>
      {date && <time class="blog-date">{date}</time>}
    </header>
    <div class="blog-body">
      <slot />
    </div>
  </article>

  <footer class="blog-footer">
    <a href="/blog" class="link-hover">← back to all posts</a>
  </footer>
</BaseLayout>

<style>
  .blog-nav {
    display: flex;
    justify-content: space-between;
    padding: 2rem var(--section-padding-x);
    font-family: var(--font-body);
    font-size: 14px;
    text-transform: lowercase;
    color: var(--text);
  }

  .blog-article {
    max-width: 920px;
    margin: 0 auto;
    padding: 4rem var(--section-padding-x) 8rem;
  }

  .blog-header {
    margin-bottom: 4rem;
  }

  .blog-title {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(36px, 6vw, 72px);
    line-height: 1;
    margin-bottom: 1rem;
    color: var(--text);
  }

  .blog-date {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .blog-body {
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.8;
    color: var(--text);
  }

  .blog-body :global(h2) {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 28px;
    margin-top: 3rem;
    margin-bottom: 1rem;
  }

  .blog-body :global(h3) {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 22px;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }

  .blog-body :global(p) {
    margin-bottom: 1.5rem;
  }

  .blog-body :global(a) {
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: opacity 0.3s;
  }

  .blog-body :global(a:hover) {
    opacity: 0.6;
  }

  .blog-body :global(blockquote) {
    border-left: 3px solid var(--text-light);
    padding-left: 1.5rem;
    margin: 2rem 0;
    color: var(--text-muted);
    font-style: italic;
  }

  .blog-body :global(code) {
    background: color-mix(in srgb, var(--text) 8%, transparent);
    padding: 0.15em 0.4em;
    border-radius: 3px;
    font-size: 0.9em;
  }

  .blog-body :global(pre) {
    background: var(--surface-dark);
    color: var(--cursor-color);
    padding: 1.5rem;
    border-radius: 4px;
    overflow-x: auto;
    margin: 2rem 0;
    font-size: 14px;
    line-height: 1.6;
  }

  .blog-body :global(pre code) {
    background: none;
    padding: 0;
    border-radius: 0;
  }

  .blog-body :global(ul),
  .blog-body :global(ol) {
    margin: 1rem 0 1.5rem 1.5rem;
  }

  .blog-body :global(li) {
    margin-bottom: 0.5rem;
  }

  .blog-body :global(hr) {
    border: none;
    border-top: 1px solid var(--text-light);
    margin: 3rem 0;
  }

  .blog-body :global(strong) {
    font-weight: 700;
  }

  .blog-body :global(em) {
    font-style: italic;
  }

  .blog-footer {
    max-width: 920px;
    margin: 0 auto;
    padding: 0 var(--section-padding-x) 4rem;
    font-size: 14px;
    color: var(--text);
  }
</style>

<script>
  import { gsap } from '../scripts/init';

  gsap.from('.blog-title', {
    y: 40,
    opacity: 0,
    duration: 0.8,
    ease: 'power3.out',
    delay: 0.2,
  });

  gsap.from('.blog-date', {
    y: 20,
    opacity: 0,
    duration: 0.6,
    ease: 'power3.out',
    delay: 0.4,
  });

  gsap.from('.blog-body', {
    y: 30,
    opacity: 0,
    duration: 0.8,
    ease: 'power3.out',
    delay: 0.5,
  });
</script>
