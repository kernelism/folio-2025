---
interface Props {
  data: {
    name: string;
    nameAudio: string;
    tagline: string;
    socialLinks: { platform: string; url: string }[];
  };
}

const { data } = Astro.props;
const [firstName, lastName] = data.name.split(' ');
---

<section class="hero" id="hero">
  <div class="hero-inner">
    <h1 class="hero-name">
      <span class="hero-name-line" data-animate="hero">
        {firstName.split('').map((char) => (
          <span class="hero-char">{char}</span>
        ))}
      </span>
      <span class="hero-name-line" data-animate="hero">
        {lastName.split('').map((char) => (
          <span class="hero-char">{char}</span>
        ))}
      </span>
    </h1>

    <p class="hero-tagline" data-animate="hero-fade">{data.tagline}</p>

    <nav class="hero-links" data-animate="hero-fade">
      {data.socialLinks.map((link, i) => (
        <>
          <a href={link.url} target="_blank" rel="noopener noreferrer" class="hero-link">{link.platform}</a>
          {i < data.socialLinks.length - 1 && <span class="hero-sep">/</span>}
        </>
      ))}
    </nav>
  </div>

</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 4vh var(--section-padding-x) 2vh;
    position: relative;
    z-index: 1;
  }

  .hero-inner {
    padding-top: 0;
  }

  .hero-name {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(48px, 12vw, 140px);
    line-height: 0.92;
    letter-spacing: -0.03em;
    color: var(--text);
  }

  .hero-name-line:last-of-type {
    position: relative;
    display: inline-block;
  }

  .hero-name-line:last-of-type::after {
    content: '';
    position: absolute;
    bottom: -0.12em;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--gradient);
    animation: hero-line 1s 0.9s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes hero-line {
    to { width: 100%; }
  }

  .hero-name-line {
    display: block;
    overflow: hidden;
  }

  .hero-char {
    display: inline-block;
  }

  .hero-tagline {
    font-family: var(--font-body);
    font-size: 13px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-top: 1rem;
    color: var(--text-muted);
  }

  .hero-links {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.9rem;
    flex-wrap: wrap;
  }

  .hero-link {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--text);
    text-decoration: none;
    transition: color 0.2s;
  }

  .hero-link:hover {
    color: var(--accent);
  }

  .hero-link {
    position: relative;
  }

  .hero-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--accent);
    transition: width 0.2s ease;
  }

  .hero-link:hover::after {
    width: 100%;
  }

  .hero-sep {
    color: var(--text-muted);
    opacity: 0.5;
  }
</style>

<script>
  import { gsap } from '../scripts/init';

  function initHero() {
    const chars = document.querySelectorAll('.hero-char');
    const fadeEls = document.querySelectorAll('[data-animate="hero-fade"]');

    gsap.set(chars, { y: '110%', opacity: 0 });
    gsap.set(fadeEls, { y: 20, opacity: 0 });

    gsap.to(chars, {
      y: '0%',
      opacity: 1,
      duration: 0.9,
      ease: 'power4.out',
      stagger: 0.03,
    });

    gsap.to(fadeEls, {
      y: 0,
      opacity: 1,
      duration: 0.6,
      ease: 'power3.out',
      stagger: 0.1,
      delay: 0.5,
    });
  }

  if (document.body.classList.contains('loaded')) {
    initHero();
  } else {
    window.addEventListener('loader-complete', initHero, { once: true });
  }
</script>
