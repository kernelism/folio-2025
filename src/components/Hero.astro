---
interface Props {
  data: {
    name: string;
    nameAudio: string;
    tagline: string;
    socialLinks: { platform: string; url: string }[];
  };
}

const { data } = Astro.props;
const [firstName, lastName] = data.name.split(' ');
---

<section class="hero" id="hero">
  <div class="hero-inner">
    <h1 class="hero-name">
      <span class="hero-name-line" data-animate="hero">
        {firstName.split('').map((char) => (
          <span class="hero-char">{char}</span>
        ))}
      </span>
      <span class="hero-name-line" data-animate="hero">
        {lastName.split('').map((char) => (
          <span class="hero-char">{char}</span>
        ))}
      </span>
    </h1>

    <p class="hero-tagline" data-animate="hero-fade">{data.tagline}</p>

    <nav class="hero-links" data-animate="hero-fade">
      {data.socialLinks.map((link, i) => (
        <>
          <a href={link.url} target="_blank" rel="noopener noreferrer" class="link-hover">
            {link.platform}
          </a>
          {i < data.socialLinks.length - 1 && <span class="hero-sep">/</span>}
        </>
      ))}
    </nav>
  </div>

  <div class="hero-scroll" data-animate="hero-fade">
    <span>scroll</span>
    <svg width="12" height="20" viewBox="0 0 12 20" fill="none">
      <path d="M6 0L6 18M6 18L1 13M6 18L11 13" stroke="currentColor" stroke-width="1.5"/>
    </svg>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 0 var(--section-padding-x);
    position: relative;
  }

  .hero-inner {
    padding-top: 10vh;
  }

  .hero-name {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(60px, 15vw, 200px);
    line-height: 0.88;
    text-transform: uppercase;
    letter-spacing: -0.03em;
  }

  .hero-name-line {
    display: block;
    overflow: hidden;
  }

  .hero-char {
    display: inline-block;
  }

  .hero-tagline {
    font-family: var(--font-body);
    font-size: clamp(12px, 1.2vw, 16px);
    text-transform: uppercase;
    letter-spacing: 0.3em;
    margin-top: 2rem;
    color: var(--text-muted);
  }

  .hero-links {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1.5rem;
    font-family: var(--font-body);
    font-size: 14px;
  }

  .hero-sep {
    color: var(--text-light);
    user-select: none;
  }

  .hero-scroll {
    position: absolute;
    bottom: 3rem;
    left: var(--section-padding-x);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--text-muted);
  }

  @media (max-width: 768px) {
    .hero-name {
      font-size: clamp(48px, 14vw, 120px);
    }

    .hero-links {
      flex-wrap: wrap;
    }
  }
</style>

<script>
  import { gsap } from '../scripts/init';

  function initHero() {
    const chars = document.querySelectorAll('.hero-char');
    const fadeEls = document.querySelectorAll('[data-animate="hero-fade"]');

    gsap.set(chars, { y: '110%', opacity: 0 });
    gsap.set(fadeEls, { y: 30, opacity: 0 });

    gsap.to(chars, {
      y: '0%',
      opacity: 1,
      duration: 1,
      ease: 'power4.out',
      stagger: 0.04,
    });

    gsap.to(fadeEls, {
      y: 0,
      opacity: 1,
      duration: 0.8,
      ease: 'power3.out',
      stagger: 0.15,
      delay: 0.6,
    });

    gsap.to('.hero-scroll', {
      y: 8,
      repeat: -1,
      yoyo: true,
      duration: 1.2,
      ease: 'power1.inOut',
    });
  }

  if (document.body.classList.contains('loaded')) {
    initHero();
  } else {
    window.addEventListener('loader-complete', initHero, { once: true });
  }
</script>
