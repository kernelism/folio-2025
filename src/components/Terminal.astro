---
---

<section class="terminal-section" id="contact">
  <div class="terminal-gap">
    <span class="terminal-deco">&</span>
  </div>

  <div class="terminal">
    <div class="terminal-bar">
      <div class="terminal-dots">
        <span class="dot"></span>
        <span class="dot"></span>
        <span class="dot"></span>
      </div>
      <span class="terminal-bar-title">arjhun@portfolio:~$</span>
    </div>

    <div class="terminal-body" id="terminal-body">
      <div class="terminal-output" id="terminal-output"></div>
      <div class="terminal-input-line" id="terminal-input-line" style="display:none">
        <span class="terminal-prompt">&gt;&nbsp;</span>
        <span class="terminal-input-display" id="terminal-input-display"></span>
        <span class="terminal-cursor" id="terminal-cursor">█</span>
      </div>
      <textarea
        id="terminal-input"
        class="terminal-hidden-input"
        autocomplete="off"
        spellcheck="false"
        aria-label="Terminal input"
      ></textarea>
    </div>
  </div>
</section>

<style>
  .terminal-section {
    display: flex;
    width: 100%;
    min-height: 420px;
    margin-top: 8vh;
  }

  .terminal-gap {
    width: 25%;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .terminal-deco {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(100px, 12vw, 180px);
    color: var(--text-light);
    opacity: 0.4;
    user-select: none;
  }

  .terminal {
    width: 75%;
    background: var(--surface-dark);
    color: var(--cursor-color);
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .terminal::before {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(245, 240, 232, 0.02) 2px,
      rgba(245, 240, 232, 0.02) 4px
    );
    pointer-events: none;
    z-index: 1;
  }

  .terminal-bar {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem 1.25rem;
    border-bottom: 1px solid rgba(245, 240, 232, 0.08);
  }

  .terminal-dots {
    display: flex;
    gap: 6px;
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--cursor-color);
    opacity: 0.25;
  }

  .dot:first-child { opacity: 0.4; }
  .dot:nth-child(2) { opacity: 0.3; }

  .terminal-bar-title {
    font-family: var(--font-body);
    font-size: 12px;
    opacity: 0.5;
  }

  .terminal-body {
    flex: 1;
    padding: 1.5rem;
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.8;
    position: relative;
    z-index: 2;
    cursor: text;
  }

  .terminal-output {
    white-space: pre-wrap;
    word-break: break-word;
  }

  .terminal-input-line {
    display: flex;
    align-items: center;
    margin-top: 0.25rem;
  }

  .terminal-prompt {
    flex-shrink: 0;
    opacity: 0.7;
  }

  .terminal-input-display {
    white-space: pre-wrap;
    word-break: break-all;
  }

  .terminal-cursor {
    animation: blink 1s step-end infinite;
    opacity: 0.9;
  }

  @keyframes blink {
    0%, 100% { opacity: 0.9; }
    50% { opacity: 0; }
  }

  .terminal-hidden-input {
    position: absolute;
    opacity: 0;
    width: 1px;
    height: 1px;
    pointer-events: none;
  }

  @media (max-width: 768px) {
    .terminal-section {
      flex-direction: column;
    }

    .terminal-gap {
      width: 100%;
      height: 80px;
    }

    .terminal {
      width: 100%;
    }

    .terminal-deco {
      font-size: 60px;
    }
  }
</style>

<script>
  import { gsap, ScrollTrigger } from '../scripts/init';

  const THINKING_WORDS = [
    'Accomplishing', 'Actioning', 'Actualizing', 'Baking', 'Brewing',
    'Calculating', 'Cerebrating', 'Churning', 'Clauding', 'Coalescing',
    'Cogitating', 'Computing', 'Conjuring', 'Considering', 'Cooking',
    'Crafting', 'Creating', 'Crunching', 'Deliberating', 'Determining',
    'Doing', 'Effecting', 'Finagling', 'Forging', 'Forming', 'Generating',
    'Hatching', 'Herding', 'Honking', 'Hustling', 'Ideating', 'Inferring',
    'Manifesting', 'Marinating', 'Moseying', 'Mulling', 'Mustering',
    'Musing', 'Noodling', 'Percolating', 'Pondering', 'Processing',
    'Puttering', 'Reticulating', 'Ruminating', 'Schlepping', 'Shucking',
    'Simmering', 'Smooshing', 'Spinning', 'Stewing', 'Synthesizing',
    'Thinking', 'Transmuting', 'Vibing', 'Working',
  ];

  function pick(arr: string[], n: number) {
    const shuffled = [...arr].sort(() => Math.random() - 0.5);
    return shuffled.slice(0, n);
  }

  const output = document.getElementById('terminal-output')!;
  const inputLine = document.getElementById('terminal-input-line')!;
  const inputDisplay = document.getElementById('terminal-input-display')!;
  const hiddenInput = document.getElementById('terminal-input') as HTMLTextAreaElement;
  const cursor = document.getElementById('terminal-cursor')!;
  const termBody = document.getElementById('terminal-body')!;

  const bootWords = pick(THINKING_WORDS, 4);
  const bootLines = [
    `${bootWords[0]}...`,
    `${bootWords[1]}...`,
    `${bootWords[2]}... done.`,
    `${bootWords[3]}... ready.`,
    '',
    '> drop a message. format: name | email | message',
  ];

  let booted = false;
  let sent = false;

  function typeLines(lines: string[], callback: () => void) {
    let lineIdx = 0;

    function typeLine() {
      if (lineIdx >= lines.length) { callback(); return; }

      const line = lines[lineIdx];
      const span = document.createElement('div');
      span.className = 'terminal-line';
      output.appendChild(span);

      if (!line) { lineIdx++; typeLine(); return; }

      let charIdx = 0;
      const interval = setInterval(() => {
        span.textContent = line.slice(0, charIdx + 1);
        charIdx++;
        if (charIdx >= line.length) {
          clearInterval(interval);
          lineIdx++;
          setTimeout(typeLine, 100);
        }
      }, 22);
    }
    typeLine();
  }

  function addLine(text: string) {
    const div = document.createElement('div');
    div.className = 'terminal-line';
    div.textContent = text;
    output.appendChild(div);
  }

  function enableInput() {
    inputLine.style.display = 'flex';
    hiddenInput.focus();
  }

  termBody.addEventListener('click', () => {
    if (booted && !sent) hiddenInput.focus();
  });

  hiddenInput.addEventListener('input', () => {
    inputDisplay.textContent = hiddenInput.value;
  });

  hiddenInput.addEventListener('keydown', async (e) => {
    if (e.key !== 'Enter' || sent) return;
    e.preventDefault();

    const raw = hiddenInput.value.trim();
    if (!raw) return;

    addLine(`> ${raw}`);
    hiddenInput.value = '';
    inputDisplay.textContent = '';

    const parts = raw.split('|').map(s => s.trim());
    if (parts.length < 3) {
      addLine('> error: use format — name | email | message');
      return;
    }

    const [name, email, ...msgParts] = parts;
    const message = msgParts.join(' | ');

    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      addLine('> error: invalid email address.');
      return;
    }

    const word = pick(THINKING_WORDS, 1)[0];
    addLine(`> ${word.toLowerCase()}...`);
    cursor.style.animation = 'none';
    cursor.style.opacity = '0.9';

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, email, message }),
      });

      const data = await res.json();

      if (data.success) {
        addLine('> message sent. thank you.');
        addLine('> connection closed.');
        sent = true;
        inputLine.style.display = 'none';
      } else {
        addLine(`> error: ${data.error || 'failed to send.'}`);
        cursor.style.animation = '';
      }
    } catch {
      if (location.hostname === 'localhost' || location.hostname === '127.0.0.1') {
        addLine('> [dev] contact api requires vercel deployment.');
        addLine(`> [dev] would send: ${name} <${email}> — "${message}"`);
      } else {
        addLine('> error: could not reach server. try again later.');
      }
      cursor.style.animation = '';
    }
  });

  ScrollTrigger.create({
    trigger: '.terminal-section',
    start: 'top 80%',
    once: true,
    onEnter: () => {
      if (booted) return;
      booted = true;
      typeLines(bootLines, enableInput);
    },
  });
</script>
