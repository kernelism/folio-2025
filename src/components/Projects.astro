---
interface ProjectItem {
  name: string;
  url: string;
  image: string;
  description: string;
  featured: boolean;
}

interface Props {
  data: { items: ProjectItem[] };
}

const { data } = Astro.props;
---

<section class="section projects" id="projects">
  <span class="section-number">03</span>
  <h2 class="section-title">Projects</h2>

  <div class="projects-list">
    {data.items.map((project) => (
      <a
        href={project.url}
        target="_blank"
        rel="noopener noreferrer"
        class="project-item"
      >
        <div class="project-thumb" aria-hidden="true">
          <img src={project.image} alt="" loading="lazy" />
          {project.featured && <span class="project-featured">★</span>}
        </div>
        <div class="project-text">
          <span class="project-head">
            <span class="project-name">{project.name}</span>
            <span class="project-arrow">↗</span>
          </span>
          <span class="project-desc">{project.description}</span>
        </div>
      </a>
    ))}
  </div>
</section>

<style>
  .projects-list {
    max-width: 700px;
    margin-left: 2vw;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .project-item {
    display: grid;
    grid-template-columns: 72px 1fr;
    gap: 1.25rem;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--card-border);
    text-decoration: none;
    color: inherit;
    transition: opacity 0.2s, transform 0.2s;
    align-items: start;
  }

  .project-item:hover {
    opacity: 1;
  }

  .project-item:hover .project-arrow {
    opacity: 0.9;
  }

  .project-item:last-child {
    border-bottom: none;
  }

  .project-thumb {
    width: 72px;
    height: 72px;
    border-radius: 8px;
    overflow: hidden;
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    position: relative;
    flex-shrink: 0;
  }

  .project-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .project-featured {
    position: absolute;
    top: 4px;
    right: 4px;
    font-size: 10px;
    color: var(--accent);
    opacity: 0.9;
  }

  .project-text {
    flex: 1;
    min-width: 0;
    position: relative;
  }

  .project-name {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 18px;
    line-height: 1.3;
    display: block;
    margin-bottom: 0.4rem;
    color: var(--text);
    transition: color 0.2s;
  }

  .project-item:hover .project-name {
    color: var(--accent);
  }

  .project-desc {
    font-family: var(--font-body);
    font-size: 13px;
    line-height: 1.5;
    color: var(--text-muted);
    display: block;
  }

  .project-head {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.4rem;
  }

  .project-arrow {
    font-size: 12px;
    color: var(--accent);
    opacity: 0;
    transition: opacity 0.2s, transform 0.2s;
  }

  @media (max-width: 600px) {
    .project-item {
      grid-template-columns: 56px 1fr;
      gap: 1rem;
      padding: 1.25rem 0;
    }

    .project-thumb {
      width: 56px;
      height: 56px;
    }
  }
</style>

<script>
  import { gsap, ScrollTrigger } from '../scripts/init';

  const items = document.querySelectorAll('.project-item');

  items.forEach((item, i) => {
    gsap.from(item, {
      y: 24,
      opacity: 0,
      duration: 0.5,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: item,
        start: 'top 90%',
        toggleActions: 'play none none none',
      },
      delay: i * 0.06,
    });
  });
</script>
