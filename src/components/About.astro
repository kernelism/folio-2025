---
interface Props {
  data: {
    paragraphs: string[];
  };
}

const { data } = Astro.props;
---

<section class="section about" id="about">
  <span class="section-number">01</span>
  <h2 class="section-title">About</h2>

  <div class="about-content">
    {data.paragraphs.map((p) => (
      <p class="about-paragraph">{p}</p>
    ))}
  </div>
</section>

<style>
  .about {
    min-height: 80vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .about-content {
    max-width: 600px;
    margin-left: 2vw;
  }

  .about-paragraph {
    font-family: var(--font-body);
    font-size: clamp(15px, 1.1vw, 18px);
    line-height: 1.8;
    margin-bottom: 1.5rem;
    color: var(--text);
  }
</style>

<script>
  import { gsap, ScrollTrigger } from '../scripts/init';

  const section = document.querySelector('.about')!;
  const number = section.querySelector('.section-number')!;
  const paragraphs = section.querySelectorAll('.about-paragraph');

  gsap.from(number, {
    y: 60,
    opacity: 0,
    scrollTrigger: {
      trigger: section,
      start: 'top 80%',
      end: 'top 20%',
      scrub: 1,
    },
  });

  paragraphs.forEach((p, i) => {
    gsap.from(p, {
      clipPath: 'inset(100% 0 0 0)',
      opacity: 0,
      duration: 0.8,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: p,
        start: 'top 85%',
        toggleActions: 'play none none none',
      },
      delay: i * 0.1,
    });
  });
</script>
