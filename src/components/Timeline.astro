---
interface TimelineEntry {
  timespan: string;
  company: string;
  role: string;
  logo: string;
  description: string;
  tags: string[];
}

interface Props {
  data: { entries: TimelineEntry[] };
}

const { data } = Astro.props;
---

<section class="timeline-section" id="experience">
  <div class="timeline-header">
    <span class="section-number">02</span>
    <h2 class="section-title">Experience</h2>
  </div>

  <div class="timeline-pin">
    <div class="timeline-progress">
      <div class="timeline-progress-fill" id="tl-progress"></div>
    </div>
    <div class="timeline-track" id="tl-track">
      {data.entries.map((entry, i) => {
        const year = entry.timespan.split(/\s/)[0];
        return (
          <div class="timeline-card" data-index={i}>
            <div class="timeline-logo-wrap">
              <img src={entry.logo} alt="" class="timeline-logo" loading="lazy" />
            </div>
            <span class="timeline-year">{year}</span>
            <div class="timeline-card-body">
              <div class="timeline-role">{entry.role}</div>
              <h3 class="timeline-company">{entry.company}</h3>
              <p class="timeline-desc">{entry.description}</p>
              <div class="timeline-tags">
                {entry.tags.map((tag) => (
                  <span class="timeline-tag">{tag}</span>
                ))}
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<style>
  .timeline-section {
    padding-top: var(--section-padding-y);
    overflow: hidden;
    z-index: 1;
    position: relative;
  }

  .timeline-header {
    padding: 0 var(--section-padding-x);
    position: relative;
    margin-bottom: 5vh;
  }

  .timeline-pin {
    width: 100%;
    overflow: hidden;
    position: relative;
  }

  .timeline-progress {
    position: absolute;
    bottom: 0;
    left: var(--section-padding-x);
    right: var(--section-padding-x);
    height: 1px;
    background: var(--card-border);
    z-index: 10;
    opacity: 0.6;
  }

  .timeline-progress-fill {
    height: 100%;
    width: 0%;
    background: var(--text-muted);
    will-change: width;
  }

  .timeline-track {
    display: flex;
    gap: 4vw;
    padding: 6vh var(--section-padding-x) 10vh;
    width: max-content;
    will-change: transform;
  }

  .timeline-card {
    flex-shrink: 0;
    width: clamp(320px, 28vw, 420px);
    position: relative;
    padding: 2.5rem 0 0;
    border-left: 1px solid var(--card-border);
    padding-left: 2rem;
    margin-left: 0.5rem;
    transition: opacity 0.2s;
  }

  .timeline-logo-wrap {
    position: absolute;
    left: -0.5rem;
    top: 0.5rem;
    width: 28px;
    height: 28px;
    border-radius: 6px;
    overflow: hidden;
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    transform: translateX(-50%);
  }

  .timeline-logo {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .timeline-card:hover {
    opacity: 0.9;
  }

  .timeline-year {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-muted);
    display: block;
    margin-bottom: 1.25rem;
  }

  .timeline-card-body {
    padding-top: 0;
  }

  .timeline-role {
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--text-muted);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .timeline-company {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(22px, 1.8vw, 28px);
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
    color: var(--text);
  }

  .timeline-desc {
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.65;
    color: var(--text);
    margin-bottom: 1.25rem;
  }

  .timeline-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .timeline-tag {
    font-family: var(--font-body);
    font-size: 11px;
    color: var(--text-muted);
    letter-spacing: 0.05em;
  }

  .timeline-tag::after {
    content: ' · ';
    margin-left: 0.25rem;
  }

  .timeline-tag:last-child::after {
    display: none;
  }

  @media (max-width: 768px) {
    .timeline-pin {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }

    .timeline-pin::-webkit-scrollbar {
      display: none;
    }

    .timeline-track {
      padding: 4vh var(--section-padding-x) 8vh;
      gap: 3rem;
    }

    .timeline-card {
      width: 85vw;
      min-width: 280px;
    }

    .timeline-progress {
      display: none;
    }
  }
</style>

<script>
  import { gsap, ScrollTrigger, lenis } from '../scripts/init';

  const pin = document.querySelector('.timeline-pin') as HTMLElement;
  const track = document.getElementById('tl-track') as HTMLElement;
  const cards = document.querySelectorAll('.timeline-card');
  const progress = document.getElementById('tl-progress');
  const isMobile = window.innerWidth <= 768;

  if (pin && track && !isMobile) {
    const totalScroll = track.scrollWidth - window.innerWidth;

    lenis.stop();
    requestAnimationFrame(() => {
      lenis.start();
      ScrollTrigger.refresh();
    });

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: pin,
        start: 'top top',
        end: () => `+=${totalScroll}`,
        pin: true,
        scrub: 0.8,
        anticipatePin: 1,
        invalidateOnRefresh: true,
        onUpdate: (self) => {
          if (progress) progress.style.width = `${self.progress * 100}%`;
        },
      },
    });

    tl.to(track, { x: -totalScroll, ease: 'none' });

    cards.forEach((card) => {
      gsap.from(card, {
        opacity: 0,
        x: 24,
        duration: 0.6,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: card,
          containerAnimation: tl,
          start: 'left 85%',
          toggleActions: 'play none none none',
        },
      });
    });
  } else if (pin && track && isMobile) {
    cards.forEach((card, i) => {
      gsap.from(card, {
        opacity: 0,
        y: 24,
        duration: 0.5,
        delay: i * 0.06,
        ease: 'power2.out',
      });
    });
  }
</script>
