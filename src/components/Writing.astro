---
interface WritingItem {
  date: string;
  title: string;
  slug?: string;
  url?: string;
  description?: string;
}

interface Props {
  data: {
    onSiteArticles: { date: string; title: string; slug: string; description: string }[];
    articles: { date: string; title: string; url: string }[];
  };
}

const { data } = Astro.props;

const MONTHS: Record<string, number> = {
  Jan: 1, Feb: 2, Mar: 3, Apr: 4, May: 5, Jun: 6,
  Jul: 7, Aug: 8, Sep: 9, Oct: 10, Nov: 11, Dec: 12
};

function parseDate(s: string): number {
  const [monthStr, yearStr] = s.split(' ');
  const m = MONTHS[monthStr] ?? 1;
  const y = parseInt(yearStr || '0', 10);
  return y * 12 + m;
}

const allItems: WritingItem[] = [
  ...data.onSiteArticles.map((a) => ({ ...a, slug: a.slug, description: a.description })),
  ...data.articles.map((a) => ({ date: a.date, title: a.title, url: a.url }))
];

allItems.sort((a, b) => parseDate(b.date) - parseDate(a.date));
---

<section class="section writing" id="writing">
  <span class="section-number">05</span>
  <h2 class="section-title">Writing</h2>

  <div class="writing-content">
    <div class="writing-list">
      {allItems.map((item) => (
        item.slug ? (
          <a href={`/blog/${item.slug}`} class="writing-item">
            <span class="writing-date">{item.date}</span>
            <span class="writing-title">{item.title}</span>
          </a>
        ) : (
          <a href={item.url!} target="_blank" rel="noopener noreferrer" class="writing-item">
            <span class="writing-date">{item.date}</span>
            <span class="writing-title">{item.title}</span>
          </a>
        )
      ))}
    </div>

    <a href="/curations" class="writing-more link-hover">→ curations</a>
  </div>
</section>

<style>
  .writing-content {
    margin-left: 2vw;
    max-width: 600px;
  }

  .writing-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .writing-item {
    display: flex;
    align-items: baseline;
    gap: 1.5rem;
    padding-left: 1.5rem;
    margin-left: 0.5rem;
    border-left: 1px solid var(--card-border);
    text-decoration: none;
    color: inherit;
    transition: opacity 0.2s;
    font-family: var(--font-body);
    font-size: 14px;
  }

  .writing-item:hover {
    opacity: 0.75;
  }

  .writing-date {
    flex-shrink: 0;
    width: 72px;
    font-size: 12px;
    color: var(--text-muted);
    letter-spacing: 0.04em;
  }

  .writing-title {
    flex: 1;
    color: var(--text);
  }

  .writing-item:hover .writing-title {
    color: var(--accent);
  }

  .writing-more {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 13px;
    margin-top: 2rem;
    color: var(--text-muted);
    transition: color 0.2s;
  }

  .writing-more:hover {
    color: var(--accent);
  }
</style>

<script>
  import { gsap, ScrollTrigger } from '../scripts/init';

  const items = document.querySelectorAll('.writing-item');

  items.forEach((item, i) => {
    gsap.from(item, {
      x: -16,
      opacity: 0,
      duration: 0.4,
      ease: 'power2.out',
      scrollTrigger: {
        trigger: item,
        start: 'top 92%',
        toggleActions: 'play none none none',
      },
      delay: i * 0.03,
    });
  });
</script>
