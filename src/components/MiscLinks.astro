---
interface MiscItem {
  title: string;
  url: string;
  note?: string;
}

interface Props {
  data: { items: MiscItem[] };
}

const { data } = Astro.props;
---

<section class="section misc" id="misc">
  <h2 class="section-title">More</h2>

  <nav class="misc-links">
    {data.items.map((item, i) => (
      <>
        {item.url ? (
          <a href={item.url} target="_blank" rel="noopener noreferrer" class="misc-link">{item.title}</a>
        ) : (
          <span class="misc-link misc-static" title={item.note}>
            {item.title}{item.note && <span class="misc-note"> ({item.note})</span>}
          </span>
        )}
        {i < data.items.length - 1 && <span class="misc-sep">·</span>}
      </>
    ))}
  </nav>
</section>

<style>
  .misc {
    padding-bottom: 8vh;
    z-index: 1;
  }

  .misc-links {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem;
    margin-left: 2vw;
    padding: 3vh 0;
    font-family: var(--font-body);
    font-size: 13px;
  }

  .misc-link {
    color: var(--text);
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .misc-link:hover {
    opacity: 0.6;
  }

  .misc-static {
    color: var(--text-muted);
    cursor: default;
  }

  .misc-sep {
    color: var(--text-muted);
    opacity: 0.4;
    user-select: none;
  }

  .misc-note {
    font-size: 11px;
    color: var(--text-muted);
  }
</style>

<script>
  import { gsap, ScrollTrigger } from '../scripts/init';

  const links = document.querySelectorAll('.misc-link');

  links.forEach((link, i) => {
    gsap.from(link, {
      opacity: 0,
      duration: 0.4,
      ease: 'power2.out',
      scrollTrigger: {
        trigger: link,
        start: 'top 92%',
        toggleActions: 'play none none none',
      },
      delay: i * 0.04,
    });
  });
</script>
