---
interface PubItem {
  title: string;
  url: string;
  venue: string;
  authors: string;
}

interface Props {
  data: { items: PubItem[] };
}

const { data } = Astro.props;
---

<section class="section publications" id="publications">
  <span class="section-number">04</span>
  <h2 class="section-title">Publications</h2>

  <div class="pubs-list">
    {data.items.map((pub) => (
      <a href={pub.url} target="_blank" rel="noopener noreferrer" class="pub-item">
        <h3 class="pub-title">{pub.title}</h3>
        <div class="pub-meta">
          <span class="pub-venue">{pub.venue}</span>
          <span class="pub-authors">{pub.authors}</span>
        </div>
      </a>
    ))}
  </div>
</section>

<style>
  .pubs-list {
    max-width: 700px;
    margin-left: 2vw;
  }

  .pub-item {
    display: block;
    padding: 2rem 0;
    border-bottom: 1px solid var(--text-light);
    text-decoration: none;
    color: inherit;
    transition: opacity 0.3s;
  }

  .pub-item:first-child {
    border-top: 1px solid var(--text-light);
  }

  .pub-item:hover {
    opacity: 0.7;
  }

  .pub-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(18px, 1.6vw, 24px);
    line-height: 1.3;
    margin-bottom: 0.75rem;
  }

  .pub-meta {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .pub-venue {
    font-family: var(--font-body);
    font-size: 13px;
    font-style: italic;
    color: var(--text-muted);
  }

  .pub-authors {
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--text-muted);
  }
</style>

<script>
  import { gsap, ScrollTrigger } from '../scripts/init';

  document.querySelectorAll('.pub-item').forEach((item, i) => {
    gsap.from(item, {
      y: 40,
      opacity: 0,
      duration: 0.6,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: item,
        start: 'top 88%',
        toggleActions: 'play none none none',
      },
      delay: i * 0.12,
    });
  });
</script>
