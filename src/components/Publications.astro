---
interface PubItem {
  title: string;
  url: string;
  venue: string;
  authors: string;
}

interface Props {
  data: { items: PubItem[] };
}

const { data } = Astro.props;
---

<section class="section publications" id="publications">
  <span class="section-number">04</span>
  <h2 class="section-title">Publications</h2>

  <div class="pubs-list">
    {data.items.map((pub) => (
      <a href={pub.url} target="_blank" rel="noopener noreferrer" class="pub-item">
        <span class="pub-venue">{pub.venue}</span>
        <h3 class="pub-title">{pub.title}</h3>
        <span class="pub-authors">{pub.authors}</span>
      </a>
    ))}
  </div>
</section>

<style>
  .pubs-list {
    max-width: 600px;
    margin-left: 2vw;
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .pub-item {
    display: block;
    text-decoration: none;
    color: inherit;
    padding-bottom: 3rem;
    border-bottom: 1px solid var(--card-border);
    transition: opacity 0.2s;
  }

  .pub-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .pub-item:hover {
    opacity: 0.85;
  }

  .pub-venue {
    font-family: var(--font-body);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--text-muted);
    display: block;
    margin-bottom: 0.75rem;
  }

  .pub-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(18px, 1.4vw, 22px);
    line-height: 1.4;
    letter-spacing: -0.01em;
    margin-bottom: 0.5rem;
    color: var(--text);
  }

  .pub-item:hover .pub-title {
    color: var(--accent);
  }

  .pub-authors {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--text-muted);
    letter-spacing: 0.01em;
  }
</style>

<script>
  import { gsap, ScrollTrigger } from '../scripts/init';

  document.querySelectorAll('.pub-item').forEach((item, i) => {
    gsap.from(item, {
      y: 32,
      opacity: 0,
      duration: 0.7,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: item,
        start: 'top 88%',
        toggleActions: 'play none none none',
      },
      delay: i * 0.1,
    });
  });
</script>
