---
const LOADER_BAR_WIDTH = 30;
const loaderEmpty = ' '.repeat(LOADER_BAR_WIDTH);
---

<div id="loader" class="loader">
  <div class="loader-terminal">
    <div class="loader-bar-row">
      <span class="loader-bar" id="loader-bar">[<span id="loader-fill"></span><span id="loader-empty">{loaderEmpty}</span>]</span>
      <span class="loader-pct" id="loader-pct">0%</span>
    </div>
  </div>
</div>

<style>
  .loader {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: 9999;
    background: var(--bg);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .loader.hiding {
    pointer-events: none;
  }

  .loader-terminal {
    font-family: var(--font-body, 'JetBrains Mono', monospace);
    color: var(--text);
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .loader-bar-row {
    font-size: clamp(14px, 2vw, 18px);
    white-space: pre;
    display: flex;
    align-items: baseline;
    line-height: 1;
  }

  .loader-bar {
    letter-spacing: 0;
    color: var(--accent);
  }

  .loader-pct {
    width: 5ch;
    text-align: right;
    opacity: 0.7;
  }
</style>

<script>
  import { gsap } from '../scripts/init';

  const SESSION_KEY = 'portfolio_loaded';

  const loader = document.getElementById('loader')!;
  const fillEl = document.getElementById('loader-fill')!;
  const emptyEl = document.getElementById('loader-empty')!;
  const pctEl = document.getElementById('loader-pct')!;
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const BAR_WIDTH = 30; // must match LOADER_BAR_WIDTH in template
  const TOTAL_DURATION = 1800;

  function completeLoader() {
    try { sessionStorage.setItem(SESSION_KEY, '1'); } catch {}
    loader.classList.add('hiding');
    gsap.to(loader, {
      opacity: 0,
      duration: 0.5,
      ease: 'power2.inOut',
      onComplete: () => {
        loader.remove();
        document.body.classList.add('loaded');
        window.dispatchEvent(new CustomEvent('loader-complete'));
      },
    });
  }

  function skipLoader() {
    loader.remove();
    document.body.classList.add('loaded');
    window.dispatchEvent(new CustomEvent('loader-complete'));
  }

  if (sessionStorage.getItem(SESSION_KEY)) {
    skipLoader();
  } else if (prefersReducedMotion) {
    completeLoader();
  } else {
    fillEl.textContent = '';
    emptyEl.textContent = ' '.repeat(BAR_WIDTH);
    pctEl.textContent = '0%';
    runLoader();
  }

  async function runLoader() {
    fillEl.textContent = '';
    emptyEl.textContent = ' '.repeat(BAR_WIDTH);

    const stepDelay = TOTAL_DURATION / BAR_WIDTH;

    for (let filled = 1; filled <= BAR_WIDTH; filled++) {
      const pct = Math.round((filled / BAR_WIDTH) * 100);
      fillEl.textContent = '#'.repeat(filled);
      emptyEl.textContent = ' '.repeat(BAR_WIDTH - filled);
      pctEl.textContent = pct < 100 ? `${pct}%` : '100%';
      await new Promise(r => setTimeout(r, stepDelay));
    }

    await new Promise(r => setTimeout(r, 200));
    completeLoader();
  }
</script>
