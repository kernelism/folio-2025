---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<BaseLayout title="Blog — Arjhun Sreedar" description="Thoughts on engineering, AI, and everything in between.">
  <nav class="blog-nav">
    <a href="/" class="link-hover">← home</a>
  </nav>

  <header class="blog-list-header">
    <h1 class="blog-list-title">Blog</h1>
    <p class="blog-list-sub">Thoughts on engineering, AI, and everything in between.</p>
  </header>

  <div class="blog-list">
    {posts.map((post) => (
      <a href={`/blog/${post.slug}`} class="blog-list-item">
        <span class="blog-list-date">{post.data.date}</span>
        <div class="blog-list-content">
          <h2 class="blog-list-item-title">{post.data.title}</h2>
          <p class="blog-list-desc">{post.data.description}</p>
        </div>
      </a>
    ))}
  </div>
</BaseLayout>

<style>
  .blog-nav {
    display: flex;
    justify-content: space-between;
    padding: 2rem var(--section-padding-x);
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--text);
  }

  .blog-list-header {
    padding: 6vh var(--section-padding-x) 4vh;
  }

  .blog-list-title {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(48px, 8vw, 100px);
    line-height: 0.9;
    text-transform: uppercase;
    margin-bottom: 1rem;
    color: var(--text);
  }

  .blog-list-sub {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--text-muted);
    letter-spacing: 0.02em;
  }

  .blog-list {
    padding: 0 var(--section-padding-x) 8rem;
    max-width: 900px;
  }

  .blog-list-item {
    display: flex;
    align-items: baseline;
    gap: 2rem;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--text-light);
    text-decoration: none;
    color: var(--text);
    transition: opacity 0.3s;
  }

  .blog-list-item:first-child {
    border-top: 1px solid var(--text-light);
  }

  .blog-list-item:hover {
    opacity: 0.65;
  }

  .blog-list-date {
    flex-shrink: 0;
    width: 100px;
    font-family: var(--font-body);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
  }

  .blog-list-content {
    flex: 1;
  }

  .blog-list-item-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(18px, 2vw, 24px);
    line-height: 1.2;
    margin-bottom: 0.25rem;
    color: var(--text);
  }

  .blog-list-desc {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--text-muted);
    line-height: 1.5;
  }

  @media (max-width: 600px) {
    .blog-list-item {
      flex-direction: column;
      gap: 0.25rem;
    }

    .blog-list-date {
      width: auto;
    }
  }
</style>

<script>
  document.body.classList.add('loaded');
</script>
