---
import BaseLayout from '../layouts/BaseLayout.astro';
import suggestions from '../data/suggestions.json';
---

<BaseLayout title="Curations — Arjhun Sreedar" description="Things I recommend: videos, books, articles.">
  <nav class="cur-nav">
    <a href="/" class="link-hover">← home</a>
    <a href="/#writing" class="link-hover">writing</a>
  </nav>

  <header class="cur-header">
    <h1 class="cur-title">Curations</h1>
    <p class="cur-sub">Things I've found valuable</p>
  </header>

  <div class="cur-content">
    {suggestions.sections.map((section) => (
      <div class="cur-section">
        <h2 class="cur-section-title">{section.title}</h2>
        <div class="cur-list">
          {section.items.map((item) => (
            <div class="cur-item">
              {item.url ? (
                <a href={item.url} target="_blank" rel="noopener noreferrer" class="cur-item-link">
                  <span class="cur-item-title">{item.title}</span>
                  <span class="cur-item-attr">{item.attribution}</span>
                </a>
              ) : (
                <div class="cur-item-link cur-item-static">
                  <span class="cur-item-title">{item.title}</span>
                  <span class="cur-item-attr">{item.attribution}</span>
                </div>
              )}
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</BaseLayout>

<style>
  .cur-nav {
    display: flex;
    justify-content: space-between;
    padding: 3rem var(--section-padding-x);
    font-family: var(--font-body);
    font-size: 13px;
    letter-spacing: 0.05em;
    text-transform: lowercase;
    position: relative;
    z-index: 1;
  }

  .cur-header {
    padding: 6vh var(--section-padding-x) 6vh;
    position: relative;
    z-index: 1;
    max-width: 720px;
  }

  .cur-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(22px, 3vw, 28px);
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-bottom: 0.35rem;
    color: var(--text);
  }

  .cur-sub {
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--text-muted);
  }

  .cur-content {
    padding: 0 var(--section-padding-x) 8rem;
    max-width: 720px;
    position: relative;
    z-index: 1;
  }

  .cur-section {
    margin-bottom: 2.5rem;
  }

  .cur-section:last-child {
    margin-bottom: 0;
  }

  .cur-section-title {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--text-muted);
    margin-bottom: 1rem;
  }

  .cur-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .cur-item {
    border-left: 1px solid var(--card-border);
    padding-left: 1.25rem;
    margin-left: 0.5rem;
  }

  .cur-item-link {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    text-decoration: none;
    color: inherit;
    transition: opacity 0.2s;
  }

  .cur-item-link:hover {
    opacity: 0.9;
  }

  .cur-item-static {
    cursor: default;
  }

  .cur-item-static:hover {
    opacity: 1;
  }

  .cur-item-title {
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 500;
    line-height: 1.4;
    color: var(--text);
  }

  a.cur-item-link:hover .cur-item-title {
    color: var(--accent);
  }

  .cur-item-attr {
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--text-muted);
  }

  @media (max-width: 600px) {
    .cur-section {
      margin-bottom: 2rem;
    }

    .cur-list {
      gap: 0.85rem;
    }
  }
</style>

<script>
  import { gsap } from '../scripts/init';

  document.body.classList.add('loaded');

  gsap.from('.cur-title', {
    y: 40,
    opacity: 0,
    duration: 0.8,
    ease: 'power3.out',
    delay: 0.1,
  });

  document.querySelectorAll('.cur-section').forEach((section, i) => {
    gsap.from(section, {
      y: 24,
      opacity: 0,
      duration: 0.6,
      ease: 'power3.out',
      delay: 0.2 + i * 0.08,
    });
  });
</script>
